@model List<Proyecto_GestionGF.Models.TipoPermiso>
@{
    ViewData["Title"] = "Tipos de permiso - Gestión GF";
    var nombre = ViewBag.Nombre as string ?? "Administrador";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="gf-dashboard-body">

    <header class="gf-header">
        <div class="gf-header-top">
            <div class="gf-logo-wrapper">
                <img src="@Url.Content("~/img/logoGF.png")" alt="Logo Grupo Fiesler" class="gf-logo-img" />
            </div>
        </div>
        <div class="gf-header-bar">
            <span class="gf-header-bar-text">Calidad y servicio que marcan la diferencia</span>
        </div>
    </header>

    <div class="gf-main-layout">

        <aside class="gf-sidebar">
            <div class="gf-sidebar-title">Gestión GF</div>
            <nav class="gf-nav">
                <ul class="gf-nav-list">
                    <li><a asp-controller="Home" asp-action="Main" class="gf-nav-link">Dashboard</a></li>
                    <li><a asp-controller="Solicitud" asp-action="HistorialAdmin" class="gf-nav-link">Historial de solicitudes</a></li>
                    <li><a asp-controller="TipoPermiso" asp-action="Index" class="gf-nav-link gf-nav-link-active">Tipos de permiso</a></li>
                    <li><a href="#" class="gf-nav-link">Usuarios</a></li>
                    <li><a href="#" class="gf-nav-link">Reportes</a></li>
                    <li><a href="#" class="gf-nav-link">Configuración</a></li>
                </ul>
            </nav>
        </aside>

        <main class="gf-content">
            <div class="gf-content-header">
                <div>
                    <h1 class="gf-page-title">Tipos de permiso</h1>
                    <p class="gf-page-subtitle">Administre los tipos de permiso disponibles en el sistema.</p>
                </div>

                <div class="gf-user-info">
                    <span class="gf-user-name">@nombre</span>
                    <a class="gf-link gf-link-logout" asp-controller="Home" asp-action="Index">Cerrar sesión</a>
                </div>
            </div>

            @if (TempData["Ok"] != null)
            {
                <div class="gf-alert gf-alert-success">@TempData["Ok"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="gf-alert gf-alert-error">@TempData["Error"]</div>
            }

            <section class="gf-table-section">
                <div class="gf-table-header-row">
                    <h2 class="gf-section-title">Listado de tipos de permiso</h2>
                    <div class="gf-table-actions">
                        <a asp-controller="TipoPermiso" asp-action="Create" class="gf-btn gf-btn-primary">Nuevo tipo</a>
                    </div>
                </div>

                <div class="gf-table-wrapper">
                    <table class="gf-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Nombre</th>
                                <th>Descripción</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || Model.Count == 0)
                            {
                                <tr>
                                    <td colspan="4">No hay tipos de permiso registrados.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.IdTipoPermiso</td>
                                        <td>@item.NombrePermiso</td>
                                        <td>@item.Descripcion</td>
                                        <td>
                                            <a asp-controller="TipoPermiso"
                                               asp-action="Edit"
                                               asp-route-id="@item.IdTipoPermiso"
                                               class="gf-table-link">
                                                Editar
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </main>
    </div>

    <footer class="gf-footer">
        <span>© @DateTime.Now.Year Grupo Fiesler | Gestión GF</span>
    </footer>

</body>
</html>
