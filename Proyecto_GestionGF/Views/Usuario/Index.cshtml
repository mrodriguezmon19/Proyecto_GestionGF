@model List<Proyecto_GestionGF.Models.Usuario>
@{
    ViewData["Title"] = "Usuarios - Gestión GF";
    var nombre = ViewBag.Nombre as string ?? "Administrador";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="gf-dashboard-body">

    <header class="gf-header">
        <div class="gf-header-top">
            <div class="gf-logo-wrapper">
                <img src="@Url.Content("~/img/logoGF.png")" alt="Logo Grupo Fiesler" class="gf-logo-img" />
            </div>
        </div>
        <div class="gf-header-bar">
            <span class="gf-header-bar-text">Calidad y servicio que marcan la diferencia</span>
        </div>
    </header>

    <div class="gf-main-layout">
        <aside class="gf-sidebar">
            <div class="gf-sidebar-title">Gestión GF</div>
            <nav class="gf-nav">
                <ul class="gf-nav-list">
                    <li><a asp-controller="Home" asp-action="Main" class="gf-nav-link">Dashboard</a></li>
                    <li><a asp-controller="Solicitud" asp-action="HistorialAdmin" class="gf-nav-link">Historial de solicitudes</a></li>
                    <li><a asp-controller="TipoPermiso" asp-action="Index" class="gf-nav-link">Tipos de permiso</a></li>
                    <li><a asp-controller="Usuario" asp-action="Index" class="gf-nav-link gf-nav-link-active">Usuarios</a></li>
                    <li><a asp-controller="Auditoria" asp-action="Index" class="gf-nav-link">Auditoría</a></li>
                    <li><a class="gf-nav-link" asp-controller="Home" asp-action="CerrarSesion">Cerrar sesión</a></li>
                </ul>
            </nav>
        </aside>

        <main class="gf-content">
            <div class="gf-content-header">
                <div>
                    <h1 class="gf-page-title">Usuarios</h1>
                    <p class="gf-page-subtitle">Gestione los usuarios registrados del sistema.</p>
                </div>

                <div class="gf-user-info">
                    <span class="gf-user-name">@nombre</span>
                    <a class="gf-link gf-link-logout" asp-controller="Home" asp-action="CerrarSesion">Cerrar sesión</a>
                </div>
            </div>

            @if (TempData["Ok"] != null)
            {
                <div class="gf-alert gf-alert-success">@TempData["Ok"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="gf-alert gf-alert-error">@TempData["Error"]</div>
            }

            <section class="gf-table-section">
                <div class="gf-table-header-row">
                    <h2 class="gf-section-title">Listado de usuarios</h2>
                    <div class="gf-table-actions">
                        <a asp-controller="Usuario" asp-action="Create" class="gf-btn gf-btn-primary">Nuevo usuario</a>
                    </div>
                </div>

                <div class="gf-table-wrapper">
                    <table class="gf-table">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Identificación</th>
                                <th>Nombre</th>
                                <th>Usuario</th>
                                <th>Correo</th>
                                <th>Rol</th>
                                <th>Departamento</th>
                                <th>Activo</th>
                                <th>Bloqueado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || Model.Count == 0)
                            {
                                <tr>
                                    <td colspan="10">No hay usuarios registrados.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.IdUsuario</td>
                                        <td>@item.Identificacion</td>
                                        <td>@item.Nombre</td>
                                        <td>@item.NombreUsuario</td>
                                        <td>@item.CorreoElectronico</td>
                                        <td>@item.NombreRol</td>
                                        <td>@item.NombreDepartamento</td>
                                        <td>@(item.Activo ? "Sí" : "No")</td>
                                        <td>@(item.Bloqueado ? "Sí" : "No")</td>
                                        <td>
                                            <div style="display:flex; gap:8px; flex-wrap:wrap;">
                                                <a asp-controller="Usuario"
                                                   asp-action="Edit"
                                                   asp-route-id="@item.IdUsuario"
                                                   class="gf-table-link">
                                                    Editar
                                                </a>

                                                @if (item.Bloqueado)
                                                {
                                                    <form asp-controller="Usuario" asp-action="Desbloquear" method="post" style="display:inline;">
                                                        @Html.AntiForgeryToken()
                                                        <input type="hidden" name="idUsuario" value="@item.IdUsuario" />
                                                        <button type="submit" class="gf-btn gf-btn-secondary">Desbloquear</button>
                                                    </form>
                                                }

                                                <form asp-controller="Usuario" asp-action="CambiarEstado" method="post" style="display:inline;">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="idUsuario" value="@item.IdUsuario" />
                                                    <input type="hidden" name="activo" value="@(!item.Activo)" />
                                                    <button type="submit" class="gf-btn gf-btn-outline">
                                                        @(item.Activo ? "Inactivar" : "Activar")
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </main>
    </div>

    <footer class="gf-footer">
        <span>© @DateTime.Now.Year Grupo Fiesler | Gestión GF</span>
    </footer>

</body>
</html>{
}
