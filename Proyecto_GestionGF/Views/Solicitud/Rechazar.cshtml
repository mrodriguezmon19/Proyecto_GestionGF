@model Proyecto_GestionGF.Models.MotivoRechazoModel

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Rechazar solicitud";
    ViewBag.Subtitulo = $"Indique el motivo del rechazo para la solicitud #{Model.IdSolicitud}.";
}

<section class="gf-form-card" style="max-width:900px; margin:0 auto;">
    <form asp-action="Rechazar" asp-controller="Solicitud" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="gf-alert gf-alert-error"></div>

        <input type="hidden" asp-for="IdSolicitud" />

        <div class="gf-form-group gf-form-group-full">
            <label class="gf-label" asp-for="MotivoRechazo">Motivo del rechazo</label>
            <textarea asp-for="MotivoRechazo"
                      class="gf-textarea"
                      rows="4"
                      placeholder="Falta documento de respaldo, fechas incorrectas, etc."></textarea>
            <span asp-validation-for="MotivoRechazo" class="text-danger"></span>
        </div>

        <div class="gf-form-actions">
            <a class="gf-btn gf-btn-secondary" asp-controller="Home" asp-action="Main">Cancelar</a>
            <button type="submit" class="gf-btn gf-btn-primary">Confirmar rechazo</button>
        </div>
    </form>
</section>

<partial name="_ValidationScriptsPartial" />

