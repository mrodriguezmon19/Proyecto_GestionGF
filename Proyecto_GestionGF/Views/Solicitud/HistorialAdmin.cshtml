@model List<Proyecto_GestionGF.Models.SolicitudHistorialModel>
@{
    ViewData["Title"] = "Historial de solicitudes - Gestión GF";
    var nombre = ViewBag.Nombre as string ?? "Administrador";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="gf-dashboard-body">

    <header class="gf-header">
        <div class="gf-header-top">
            <div class="gf-logo-wrapper">
                <img src="@Url.Content("~/img/logoGF.png")"
                     alt="Logo Grupo Fiesler"
                     class="gf-logo-img" />
            </div>
        </div>
        <div class="gf-header-bar">
            <span class="gf-header-bar-text">
                Calidad y servicio que marcan la diferencia
            </span>
        </div>
    </header>

    <div class="gf-main-layout">

        <aside class="gf-sidebar">
            <div class="gf-sidebar-title">Gestión GF</div>
            <nav class="gf-nav">
                <ul class="gf-nav-list">
                    <li><a asp-controller="Home" asp-action="Main" class="gf-nav-link">Dashboard</a></li>
                    <li><a asp-controller="Solicitud" asp-action="HistorialAdmin" class="gf-nav-link gf-nav-link-active">Historial de solicitudes</a></li>
                    <li><a asp-controller="TipoPermiso" asp-action="Index" class="gf-nav-link">Tipos de permiso</a></li>
                    <li><a asp-controller="Auditoria" asp-action="Index" class="gf-nav-link">Auditoría</a></li>
                    <li><a href="#" class="gf-nav-link">Usuarios</a></li>
                    <li><a href="#" class="gf-nav-link">Reportes</a></li>
                    <li><a href="#" class="gf-nav-link">Configuración</a></li>
                </ul>
            </nav>
        </aside>

        <main class="gf-content">
            <div class="gf-content-header">
                <div>
                    <h1 class="gf-page-title">Historial de solicitudes</h1>
                    <p class="gf-page-subtitle">Consulta completa del historial de permisos registrados.</p>
                </div>

                <div class="gf-user-info">
                    <span class="gf-user-name">@nombre</span>
                    <a class="gf-link gf-link-logout" asp-controller="Home" asp-action="CerrarSesion">Cerrar sesión</a>
                </div>
            </div>

            @if (TempData["Ok"] != null)
            {
                <div class="gf-alert gf-alert-success">@TempData["Ok"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="gf-alert gf-alert-error">@TempData["Error"]</div>
            }

            <section class="gf-table-section">
                <div class="gf-table-wrapper">
                    <table class="gf-table">
                        <thead>
                            <tr>
                                <th>Nº</th>
                                <th>Colaborador</th>
                                <th>Tipo</th>
                                <th>Motivo</th>
                                <th>Fecha inicio</th>
                                <th>Fecha fin</th>
                                <th>Estado</th>
                                <th>Adjunto</th>
                                <th>Motivo rechazo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || Model.Count == 0)
                            {
                                <tr>
                                    <td colspan="9">No hay solicitudes registradas.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var s in Model)
                                {
                                    <tr>
                                        <td>@s.IdSolicitud</td>
                                        <td>@s.NombreUsuario</td>
                                        <td>@s.NombrePermiso</td>
                                        <td>@s.MotivoRechazo</td>
                                        <td>@s.FechaInicio.ToString("dd-MM-yyyy")</td>
                                        <td>@s.FechaFinal.ToString("dd-MM-yyyy")</td>

                                        <td>
                                            @if (s.Estado == 0)
                                            {
                                                <span class="gf-badge gf-badge-pending">Pendiente</span>
                                            }
                                            else if (s.Estado == 1)
                                            {
                                                <span class="gf-badge gf-badge-approved">Aprobado</span>
                                            }
                                            else if (s.Estado == 2)
                                            {
                                                <span class="gf-badge gf-badge-rejected">Rechazado</span>
                                            }
                                            else
                                            {
                                                <span class="gf-badge">Cancelado</span>
                                            }
                                        </td>

                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(s.ArchivoFile))
                                            {
                                                <a class="gf-table-link" href="@s.ArchivoFile" target="_blank">Ver</a>
                                            }
                                            else
                                            {
                                                <span>-</span>
                                            }
                                        </td>

                                        <td>
                                            @if (s.Estado == 2 && !string.IsNullOrWhiteSpace(s.MotivoRechazo))
                                            {
                                                <span class="gf-table-link" title="@s.MotivoRechazo">Ver motivo</span>
                                            }
                                            else
                                            {
                                                <span>-</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </main>
    </div>

    <footer class="gf-footer">
        <span>© @DateTime.Now.Year Grupo Fiesler | Gestión GF</span>
    </footer>

</body>
</html>