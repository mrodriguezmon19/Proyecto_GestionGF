@model List<Proyecto_GestionGF.Models.AuditoriaModel>
@{
    ViewData["Title"] = "Auditoría - Gestión GF";
    var nombre = ViewBag.Nombre as string ?? "Administrador";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="gf-dashboard-body">

    <header class="gf-header">
        <div class="gf-header-top">
            <div class="gf-logo-wrapper">
                <img src="@Url.Content("~/img/logoGF.png")" alt="Logo Grupo Fiesler" class="gf-logo-img" />
            </div>
        </div>
        <div class="gf-header-bar">
            <span class="gf-header-bar-text">Calidad y servicio que marcan la diferencia</span>
        </div>
    </header>

    <div class="gf-main-layout">

        <aside class="gf-sidebar">
            <div class="gf-sidebar-title">Gestión GF</div>
            <nav class="gf-nav">
                <ul class="gf-nav-list">
                    <li><a asp-controller="Home" asp-action="Main" class="gf-nav-link">Dashboard</a></li>
                    <li><a asp-controller="Solicitud" asp-action="HistorialAdmin" class="gf-nav-link gf-nav-link-active">Historial de solicitudes</a></li>
                    <li><a asp-controller="TipoPermiso" asp-action="Index" class="gf-nav-link">Tipos de permiso</a></li>
                    <li><a asp-controller="Auditoria" asp-action="Index" class="gf-nav-link">Auditoría</a></li>
                    <li><a asp-controller="Usuario" asp-action="Index" class="gf-nav-link">Usuarios</a></li>
                    <li><a href="#" class="gf-nav-link">Reportes</a></li>
                    <li><a href="#" class="gf-nav-link">Configuración</a></li>
                </ul>
            </nav>
        </aside>

        <main class="gf-content">



            <section class="gf-table-section">
                <div class="gf-table-wrapper">
                    <table class="gf-table">
                        <thead>
                            <tr>
                                <th>ID Auditoría</th>
                                <th>Solicitud</th>
                                <th>Usuario</th>
                                <th>Rol</th>
                                <th>Departamento</th>
                                <th>Acción</th>
                                <th>Resultado</th>
                                <th>Motivo rechazo</th>
                                <th>Fecha</th>
                                <th>Estación/IP</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model == null || Model.Count == 0)
                            {
                                <tr>
                                    <td colspan="10">No hay registros de auditoría.</td>
                                </tr>
                            }
                            else
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td>@item.IdAuditoria</td>
                                        <td>@item.IdSolicitud</td>
                                        <td>@item.NombreUsuario</td>
                                        <td>@item.NombreRol</td>
                                        <td>@item.NombreDepartamento</td>
                                        <td>@item.Accion</td>
                                        <td>@item.Resultado</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.MotivoRechazo) ? "-" : item.MotivoRechazo)</td>
                                        <td>@item.FechaCambio.ToString("dd-MM-yyyy HH:mm")</td>
                                        <td>@(string.IsNullOrWhiteSpace(item.EstacionTrabajo) ? "-" : item.EstacionTrabajo)</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </section>
        </main>
    </div>

    <footer class="gf-footer">
        <span>© @DateTime.Now.Year Grupo Fiesler | Gestión GF</span>
    </footer>

</body>
</html>
