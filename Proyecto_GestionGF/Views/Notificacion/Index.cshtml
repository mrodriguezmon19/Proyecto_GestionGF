@model List<Proyecto_GestionGF.Models.NotificacionModel>

@{
    var noLeidas = (int)(ViewBag.NoLeidas ?? 0);
    var idRol = Context.Session.GetInt32("IdRol") ?? 0;

    Layout = (idRol == 1 || idRol == 2)
        ? "~/Views/Shared/_LayoutAdmin.cshtml"
        : "~/Views/Shared/_LayoutUsuario.cshtml";

    ViewData["Title"] = "Notificaciones";
    ViewBag.Subtitulo = $"Tenés {noLeidas} notificación(es) sin leer.";
}

<section class="gf-form-card" style="max-width:1000px; margin:0 auto;">

    <div class="gf-table-header-row" style="margin-bottom: 1rem;">
        <h2 class="gf-section-title">Centro de notificaciones</h2>

        <div class="gf-table-actions">
            <form asp-action="MarcarTodasLeidas" method="post" style="display:inline;">
                @Html.AntiForgeryToken()
                <button class="gf-btn gf-btn-outline" type="submit">
                    Marcar todas como leídas
                </button>
            </form>

            @if (idRol == 1 || idRol == 2)
            {
                <a class="gf-btn gf-btn-secondary" asp-controller="Home" asp-action="Main">Volver</a>
            }
            else
            {
                <a class="gf-btn gf-btn-secondary" asp-controller="Home" asp-action="MainUsuario">Volver</a>
            }
        </div>
    </div>

    @if (Model == null || Model.Count == 0)
    {
        <div>No tenés notificaciones aún.</div>
    }
    else
    {
        <div style="display:flex; flex-direction:column; gap:12px;">
            @foreach (var n in Model)
            {
                <div class="gf-alert @(n.Leida ? "" : "gf-alert-success")"
                     style="display:flex; justify-content:space-between; gap:12px; align-items:flex-start;">

                    <div>
                        <strong>@n.Titulo</strong><br />
                        <span>@n.Mensaje</span><br />
                        <small>@n.FechaCreacion.ToString("dd-MM-yyyy HH:mm")</small>
                    </div>

                    @if (!n.Leida)
                    {
                        <form asp-action="MarcarLeida" method="post" style="display:inline;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="idNotificacion" value="@n.IdNotificacion" />
                            <button class="gf-btn gf-btn-primary" type="submit">Marcar leída</button>
                        </form>
                    }
                </div>
            }
        </div>
    }
</section>

