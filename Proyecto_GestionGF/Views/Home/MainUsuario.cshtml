@model Proyecto_GestionGF.Models.UsuarioDashboardModel

@{
    Layout = "~/Views/Shared/_LayoutUsuario.cshtml";
    ViewData["Title"] = "Mi panel";
    ViewBag.Subtitulo = "Podés crear y dar seguimiento a tus permisos.";
    ViewBag.Menu = "Panel";
}

<section class="gf-kpi-grid">

    <article class="gf-kpi-card">
        <h2 class="gf-kpi-label">Pendientes</h2>
        <p class="gf-kpi-value">@Model.TotalPendientes</p>
        <span class="gf-kpi-helper">En revisión</span>
    </article>

    <article class="gf-kpi-card">
        <h2 class="gf-kpi-label">Aprobados</h2>
        <p class="gf-kpi-value">@Model.TotalAprobados</p>
        <span class="gf-kpi-helper">Histórico</span>
    </article>

    <article class="gf-kpi-card">
        <h2 class="gf-kpi-label">Rechazados</h2>
        <p class="gf-kpi-value">@Model.TotalRechazados</p>
        <span class="gf-kpi-helper">Histórico</span>
    </article>

    <article class="gf-kpi-card">
        <h2 class="gf-kpi-label">Próximos</h2>
        <p class="gf-kpi-value">@Model.TotalProximos</p>
        <span class="gf-kpi-helper">En próximos 7 días</span>
    </article>

</section>

<section class="gf-table-section">
    <div class="gf-table-header-row">
        <h2 class="gf-section-title">Mis últimas solicitudes</h2>
        <div class="gf-table-actions">
            <a class="gf-btn gf-btn-outline" asp-controller="Solicitud" asp-action="MisSolicitudes">Ver más</a>
            <a class="gf-btn gf-btn-primary" asp-controller="Solicitud" asp-action="CrearSolicitud">Crear</a>
        </div>
    </div>

    <div class="gf-table-wrapper">
        <table class="gf-table">
            <thead>
                <tr>
                    <th>Nº</th>
                    <th>Tipo</th>
                    <th>Fecha inicio</th>
                    <th>Fecha fin</th>
                    <th>Estado</th>
                    <th>Motivo</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model?.UltimasSolicitudes == null || Model.UltimasSolicitudes.Count == 0)
                {
                    <tr>
                        <td colspan="7">No tenés solicitudes registradas.</td>
                    </tr>
                }
                else
                {
                    foreach (var s in Model.UltimasSolicitudes)
                    {
                        <tr>
                            <td>@s.IdSolicitud</td>
                            <td>@s.TipoPermiso</td>
                            <td>@s.FechaInicio.ToString("dd-MM-yyyy")</td>
                            <td>@s.FechaFinal.ToString("dd-MM-yyyy")</td>

                            <td>
                                @if (s.Estado == 0)
                                {
                                    <span class="gf-badge gf-badge-pending">Pendiente</span>
                                }
                                else if (s.Estado == 1)
                                {
                                    <span class="gf-badge gf-badge-approved">Aprobado</span>
                                }
                                else if (s.Estado == 2)
                                {
                                    <span class="gf-badge gf-badge-rejected" title="@s.MotivoRechazo">Rechazado</span>
                                }
                                else
                                {
                                    <span class="gf-badge">Cancelado</span>
                                }
                            </td>

                            <td>@s.Motivo</td>

                            <td>
                                <div style="display:flex; gap:8px; flex-wrap:wrap;">
                                    @if (!string.IsNullOrWhiteSpace(s.ArchivoFile))
                                    {
                                        <a class="gf-btn gf-btn-outline" href="@s.ArchivoFile" target="_blank">Adjunto</a>
                                    }

                                    @if (s.Estado == 0)
                                    {
                                        <form asp-controller="Solicitud"
                                              asp-action="Cancelar"
                                              method="post"
                                              style="display:inline;"
                                              onsubmit="return confirm('¿Seguro que deseas cancelar esta solicitud?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="idSolicitud" value="@s.IdSolicitud" />
                                            <button type="submit" class="gf-btn gf-btn-secondary">Cancelar</button>
                                        </form>
                                    }
                                    else if (s.Estado == 2 && !string.IsNullOrWhiteSpace(s.MotivoRechazo))
                                    {
                                        <span class="gf-table-link" title="@s.MotivoRechazo">Ver motivo</span>
                                    }
                                    else
                                    {
                                        <span>-</span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>

