@{
    ViewData["Title"] = "Panel Usuario - Gestión GF";
    var nombre = ViewBag.Nombre as string ?? "Usuario";
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="gf-dashboard-body">

    <!-- HEADER -->
    <header class="gf-header">
        <div class="gf-header-top">
            <div class="gf-logo-wrapper">
                <img src="@Url.Content("~/img/logo.png")" alt="Logo Grupo Fiesler" class="gf-logo-img" />
            </div>
        </div>
        <div class="gf-header-bar">
            <span class="gf-header-bar-text">Calidad y servicio que marcan la diferencia</span>
        </div>
    </header>

    <!-- LAYOUT -->
    <div class="gf-main-layout">
        <!-- SIDEBAR USUARIO -->
        <aside class="gf-sidebar">
            <div class="gf-sidebar-title">Gestión GF</div>
            <nav class="gf-nav">
                <ul class="gf-nav-list">
                    <li><a class="gf-nav-link gf-nav-link-active" asp-controller="Home" asp-action="MainUsuario">Mi panel</a></li>
                    <li><a class="gf-nav-link" asp-controller="Solicitud" asp-action="CrearSolicitud">Nueva solicitud</a></li>
                    <li><a class="gf-nav-link" asp-controller="Solicitud" asp-action="MisSolicitudes">Mis solicitudes</a></li>
                    <li><a class="gf-nav-link" asp-controller="Home" asp-action="Index">Cerrar sesión</a></li>
                </ul>
            </nav>
        </aside>

        <!-- CONTENIDO -->
        <main class="gf-content">
            <!-- Encabezado -->
            <div class="gf-content-header">
                <div>
                    <h1 class="gf-page-title">Hola, @nombre</h1>
                    <p class="gf-page-subtitle">Este es tu panel. Podés crear y dar seguimiento a tus permisos.</p>
                </div>
                <div class="gf-user-info">
                    <span class="gf-user-name">@nombre</span>
                    <a class="gf-link gf-link-logout" asp-controller="Home" asp-action="Index">Cerrar sesión</a>
                </div>
            </div>

            <!-- KPIs / Resumen personal -->
            <section class="gf-kpi-grid">
                <article class="gf-kpi-card">
                    <h2 class="gf-kpi-label">Pendientes</h2>
                    <p class="gf-kpi-value"></p>
                    <span class="gf-kpi-helper">En revisión</span>
                </article>
                <article class="gf-kpi-card">
                    <h2 class="gf-kpi-label">Aprobados</h2>
                    <p class="gf-kpi-value"></p>
                    <span class="gf-kpi-helper">Histórico</span>
                </article>
                <article class="gf-kpi-card">
                    <h2 class="gf-kpi-label">Rechazados</h2>
                    <p class="gf-kpi-value"></p>
                    <span class="gf-kpi-helper">Histórico</span>
                </article>
                <article class="gf-kpi-card">
                    <h2 class="gf-kpi-label">Próximos</h2>
                    <p class="gf-kpi-value"></p>
                    <span class="gf-kpi-helper">En próximos 7 días</span>
                </article>
            </section>

            <!-- Acciones rápidas -->
            <section class="gf-filters-bar" style="margin-bottom:1.5rem;">
                <div class="gf-filters-group">
                    <div class="gf-form-group">
                        <label class="gf-label">Rango</label>
                        <input type="date" class="gf-input" />
                    </div>
                    <div class="gf-form-group">
                        <label class="gf-label">&nbsp;</label>
                        <input type="date" class="gf-input" />
                    </div>
                    <div class="gf-form-group">
                        <label class="gf-label">Estado</label>
                        <select class="gf-input">
                            <option value="">Todos</option>
                            <option>Pendiente</option>
                            <option>Aprobado</option>
                            <option>Rechazado</option>
                        </select>
                    </div>
                </div>
                <div class="gf-filters-actions">
                    <a class="gf-btn gf-btn-secondary" asp-controller="Solicitud" asp-action="MisSolicitudes">Ver todas</a>
                    <a class="gf-btn gf-btn-primary" asp-controller="Solicitud" asp-action="CrearSolicitud">Nueva solicitud</a>
                </div>
            </section>

            <!-- Tabla de últimas solicitudes del usuario -->
            <section class="gf-table-section">
                <div class="gf-table-header-row">
                    <h2 class="gf-section-title">Mis últimas solicitudes</h2>
                    <div class="gf-table-actions">
                        <a class="gf-btn gf-btn-outline" asp-controller="Solicitud" asp-action="MisSolicitudes">Ver más</a>
                        <a class="gf-btn gf-btn-primary" asp-controller="Solicitud" asp-action="CrearSolicitud">Crear</a>
                    </div>
                </div>

                <div class="gf-table-wrapper">
                    <table class="gf-table">
                        <thead>
                            <tr>
                                <th>Nº</th>
                                <th>Tipo</th>
                                <th>Fecha inicio</th>
                                <th>Fecha fin</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>

                        </tbody>
                    </table>
                </div>
            </section>
        </main>
    </div>

    <footer class="gf-footer">
        <span>© @DateTime.Now.Year Grupo Fiesler | Gestión GF</span>
    </footer>
</body>
</html>
