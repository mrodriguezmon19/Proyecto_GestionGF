@{
    ViewData["Title"] = "Recuperar contraseña";
}

<div class="gf-content-header">
    <div>
        <h1 class="gf-page-title">Recuperar contraseña</h1>
        <p class="gf-page-subtitle">Ingrese su correo para generar un enlace de recuperación.</p>
    </div>
</div>

<section class="gf-form-card">

    <form asp-action="RecuperarPassword" method="post" class="gf-login-form">

        <div class="gf-form-group">
            <label class="gf-label">Correo electrónico</label>
            <input type="email" name="correo" class="gf-input" required />
        </div>

        <div class="gf-form-actions">
            <button type="submit" class="gf-btn gf-btn-primary">
                Generar enlace
            </button>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="gf-alert gf-alert-error">@TempData["Error"]</div>
        }

        @if (ViewBag.Link != null)
        {
            <div class="gf-alert gf-alert-success">
                <strong>Enlace generado:</strong><br />
                <a href="@ViewBag.Link">@ViewBag.Link</a>
            </div>
        }

    </form>

</section>