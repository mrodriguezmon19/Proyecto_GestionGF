@model Proyecto_GestionGF.Models.AdminDashboardModel

@{
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
    ViewData["Title"] = "Dashboard administrador";
    ViewBag.Subtitulo = "Resumen de solicitudes de permisos del personal.";
    ViewBag.Menu = "Dashboard";
}

<section class="gf-kpi-grid">

    <article class="gf-kpi-card">
        <h2 class="gf-kpi-label">Permisos pendientes</h2>
        <p class="gf-kpi-value">@Model.TotalPendientes</p>
        <span class="gf-kpi-helper">En espera de aprobación</span>
    </article>

    <article class="gf-kpi-card">
        <h2 class="gf-kpi-label">Aprobados</h2>
        <p class="gf-kpi-value">@Model.TotalAprobados</p>
        <span class="gf-kpi-helper">Histórico</span>
    </article>

    <article class="gf-kpi-card">
        <h2 class="gf-kpi-label">Rechazados</h2>
        <p class="gf-kpi-value">@Model.TotalRechazados</p>
        <span class="gf-kpi-helper">Histórico</span>
    </article>

    <article class="gf-kpi-card">
        <h2 class="gf-kpi-label">Próximos 7 días</h2>
        <p class="gf-kpi-value">@Model.TotalProximos</p>
        <span class="gf-kpi-helper">Permisos en calendario</span>
    </article>

</section>

<form asp-action="Main" method="get">
    <section class="gf-filters-bar">

        <div class="gf-filters-group">

            <div class="gf-form-group">
                <label class="gf-label">Desde</label>
                <input type="date"
                       name="desde"
                       class="gf-input"
                       value="@Context.Request.Query["desde"]" />
            </div>

            <div class="gf-form-group">
                <label class="gf-label">Hasta</label>
                <input type="date"
                       name="hasta"
                       class="gf-input"
                       value="@Context.Request.Query["hasta"]" />
            </div>

            <div class="gf-form-group">
                <label class="gf-label">Estado</label>
                <select name="estado" class="gf-input">
                    <option value="">Todos</option>
                    <option value="0" selected="@(Context.Request.Query["estado"] == "0")">Pendiente</option>
                    <option value="1" selected="@(Context.Request.Query["estado"] == "1")">Aprobado</option>
                    <option value="2" selected="@(Context.Request.Query["estado"] == "2")">Rechazado</option>
                </select>
            </div>

        </div>

        <div class="gf-filters-actions">
            <a asp-action="Main" class="gf-btn gf-btn-secondary">Limpiar</a>
            <button type="submit" class="gf-btn gf-btn-primary">Filtrar</button>
        </div>

    </section>
</form>

<section class="gf-table-section">

    <div class="gf-table-header-row">
        <h2 class="gf-section-title">Solicitudes recientes</h2>

        <div class="gf-table-actions">
            <a asp-action="ExportarPdf"
               asp-route-desde="@Context.Request.Query["desde"]"
               asp-route-hasta="@Context.Request.Query["hasta"]"
               asp-route-estado="@Context.Request.Query["estado"]"
               class="gf-btn gf-btn-outline">
                Exportar PDF
            </a>

            <a asp-action="ExportarExcel"
               asp-route-desde="@Context.Request.Query["desde"]"
               asp-route-hasta="@Context.Request.Query["hasta"]"
               asp-route-estado="@Context.Request.Query["estado"]"
               class="gf-btn gf-btn-primary">
                Exportar Excel
            </a>
        </div>
    </div>

    <div class="gf-table-wrapper">
        <table class="gf-table">
            <thead>
                <tr>
                    <th>Nº</th>
                    <th>Colaborador</th>
                    <th>Tipo</th>
                    <th>Motivo</th>
                    <th>Fecha inicio</th>
                    <th>Fecha fin</th>
                    <th>Estado</th>
                    <th>Adjunto</th>
                    <th>Acciones</th>
                </tr>
            </thead>

            <tbody>
                @if (Model?.Solicitudes == null || Model.Solicitudes.Count == 0)
                {
                    <tr>
                        <td colspan="9">No hay solicitudes registradas.</td>
                    </tr>
                }
                else
                {
                    foreach (var s in Model.Solicitudes)
                    {
                        <tr>
                            <td>@s.IdSolicitud</td>
                            <td>@s.Colaborador</td>
                            <td>@s.TipoPermiso</td>
                            <td>@s.Motivo</td>
                            <td>@s.FechaInicio.ToString("dd-MM-yyyy")</td>
                            <td>@s.FechaFinal.ToString("dd-MM-yyyy")</td>

                            <td>
                                @if (s.Estado == 0)
                                {
                                    <span class="gf-badge gf-badge-pending">Pendiente</span>
                                }
                                else if (s.Estado == 1)
                                {
                                    <span class="gf-badge gf-badge-approved">Aprobado</span>
                                }
                                else
                                {
                                    <span class="gf-badge gf-badge-rejected">Rechazado</span>
                                }
                            </td>

                            <td>
                                @if (!string.IsNullOrWhiteSpace(s.ArchivoFile))
                                {
                                    <a class="gf-table-link" href="@s.ArchivoFile" target="_blank">Ver</a>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>

                            <td>
                                @if (s.Estado == 0)
                                {
                                    <div style="display:flex; gap:8px;">
                                        <form asp-controller="Solicitud" asp-action="Aprobar" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="idSolicitud" value="@s.IdSolicitud" />
                                            <button type="submit" class="gf-btn gf-btn-primary">Aprobar</button>
                                        </form>

                                        <a class="gf-btn gf-btn-primary"
                                           asp-controller="Solicitud"
                                           asp-action="Rechazar"
                                           asp-route-id="@s.IdSolicitud">
                                            Rechazar
                                        </a>
                                    </div>
                                }
                                else if (s.Estado == 2 && !string.IsNullOrWhiteSpace(s.MotivoRechazo))
                                {
                                    <span class="gf-table-link" title="@s.MotivoRechazo">Ver motivo</span>
                                }
                                else
                                {
                                    <span>-</span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>

        </table>
    </div>
</section>


