@model string

@{
    ViewData["Title"] = "Cambiar contraseña";
}

<div class="gf-content-header">
    <div>
        <h1 class="gf-page-title">Nueva contraseña</h1>
        <p class="gf-page-subtitle">Ingrese su nueva contraseña.</p>
    </div>
</div>

<section class="gf-form-card">

    <form asp-action="CambiarPassword" method="post" class="gf-login-form">

        <input type="hidden" name="token" value="@Model" />

        <div class="gf-form-group">
            <label class="gf-label">Nueva contraseña</label>
            <input type="password" name="nuevaPassword" class="gf-input" required />
        </div>

        <div class="gf-form-actions">
            <button type="submit" class="gf-btn gf-btn-primary">
                Guardar contraseña
            </button>
        </div>

        @if (TempData["Error"] != null)
        {
            <div class="gf-alert gf-alert-error">@TempData["Error"]</div>
        }

    </form>

</section>